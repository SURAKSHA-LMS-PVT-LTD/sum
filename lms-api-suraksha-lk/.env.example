# =============================================================================
# LMS API (Suraksha) — ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in every value marked CHANGE_ME.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Generate secrets:
#   openssl rand -hex 64          (128-char hex string — use for JWT/pepper/keys)
#   openssl rand -hex 32          (64-char hex string — use for DRIVE_TOKEN/TELEGRAM)
# =============================================================================

# ============================================
# CORE APPLICATION
# ============================================
NODE_ENV=production
PORT=8080
TZ=Asia/Colombo

# ============================================
# DATABASE — Cloud SQL via Auth Proxy
# ============================================
# Auth Proxy listens on 127.0.0.1:3306. Do NOT change DB_HOST or DB_PORT.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=suraksha_lms_db
DB_USERNAME=lms_user
DB_PASSWORD=CHANGE_ME            # set via Terraform db_password variable
DB_POOL_SIZE=20
DB_CONNECTION_LIMIT=25

# ============================================
# JWT AUTHENTICATION (REQUIRED — min 64 chars each)
# ============================================
# Generate: openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
# JWT_EXPIRATION and JWT_EXPIRES_IN are both checked; set one or both.
JWT_EXPIRATION=15m
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Signed upload tokens (can reuse JWT_SECRET or be a separate key)
UPLOAD_TOKEN_SECRET=CHANGE_ME

# ============================================
# PASSWORD SECURITY
# ============================================
BCRYPT_SALT_ROUNDS=12
# CRITICAL: BCRYPT_PEPPER must NEVER change after first deployment.
# Changing it invalidates ALL existing password hashes — requires a migration.
# Generate: openssl rand -hex 64
BCRYPT_PEPPER=CHANGE_ME

# ============================================
# APPLICATION URLs
# ============================================
APP_URL=https://lmsapi.suraksha.lk
FRONTEND_URL=https://lms.suraksha.lk
WEB_APP_URL=https://lms.suraksha.lk
BASE_DOMAIN=suraksha.lk
MOBILE_APP_SCHEME=suraksha
FRONTEND_PROFILE_URL=https://lms.suraksha.lk/profile
APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=lk.suraksha.lms

# ============================================
# CORS (comma-separated origins)
# ============================================
CORS_ORIGINS=https://lms.suraksha.lk,https://org.suraksha.lk,https://admin.suraksha.lk,https://transport.suraksha.lk

# Custom institute domains that are verified in the DB (optional static seed)
CUSTOM_DOMAIN_ORIGINS=

# ============================================
# SPECIAL API KEY (privileged internal endpoints)
# ============================================
# Generate: openssl rand -hex 32
SPECIAL_API_KEY=CHANGE_ME

# ============================================
# RATE LIMITING / THROTTLING
# ============================================
THROTTLE_TTL=30000
THROTTLE_LIMIT=100
THROTTLE_LIMIT_LOGIN=10
RATE_LIMIT_WINDOW_SECONDS=30
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ============================================
# CORS (comma-separated origins)
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com,https://admin.yourdomain.com

# (See APPLICATION URLs section above)

# ============================================
# CONTACT DATA MASKING
# ============================================
IS_PHONENUMBERS_MASKED=false
IS_EMAILS_MASKED=false

# ============================================
# CLOUD STORAGE PROVIDER (google | aws | local)
# ============================================
STORAGE_PROVIDER=google

# --- Google Cloud Storage ---
GCS_PROJECT_ID=CHANGE_ME
GCS_BUCKET_NAME=CHANGE_ME                        # e.g. your-project-id-lms-media
GCS_BASE_URL=https://storage.googleapis.com
STORAGE_BASE_URL=https://storage.googleapis.com
# Alias used by some services — keep in sync with GCS_BUCKET_NAME
GOOGLE_STORAGE_BUCKET=CHANGE_ME
GCS_CLIENT_EMAIL=CHANGE_ME                       # service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
GCS_PRIVATE_KEY_ID=CHANGE_ME
GCS_CLIENT_ID=CHANGE_ME
GCS_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCS_TOKEN_URI=https://oauth2.googleapis.com/token
GCS_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs

# GCS Backup Bucket (Cloud SQL exports — set to terraform output backup_bucket)
BACKUP_BUCKET=CHANGE_ME                          # e.g. gs://your-project-id-lms-backups

# --- Amazon S3 (alternative) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# --- Local Storage (development) ---
LOCAL_STORAGE_BASE_URL=http://localhost:3000/uploads
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_PUBLIC_PATH=/uploads

# ============================================
# Firebase Cloud Messaging (push notifications)
# ============================================
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_CLIENT_EMAIL=CHANGE_ME                  # firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
# Test FCM device token for dev/staging only — leave empty in production
TEST_FCM_TOKEN=

# ============================================
# Google OAuth (Drive integration)
# ============================================
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# AES-256-GCM key for encrypting stored OAuth Drive tokens
# Generate: openssl rand -hex 32
DRIVE_TOKEN_ENCRYPTION_KEY=CHANGE_ME

# ============================================
# SMS (SMSlenz.lk)
# ============================================
USE_SYSTEM_SMS_CREDENTIALS=true
SMSLENZ_USER_ID=CHANGE_ME
SMSLENZ_API_KEY=CHANGE_ME
SMSLENZ_BASE_URL=https://api.smslenz.com
SMSLENZ_DEFAULT_SENDER_ID=YourSenderID
SMS_MAX_BULK_COUNT_DEFAULT=1000

# ============================================
# WhatsApp Business API
# ============================================
WHATSAPP_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_TEMPLATE_ENABLED=false

# ============================================
# Email API
# ============================================
EMAIL_API_URL=CHANGE_ME
EMAIL_SERVER_URL=CHANGE_ME
EMAIL_SERVER_AUTH_TOKEN=CHANGE_ME

# ============================================
# REDIS (Caching)
# ============================================
CACHE_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME                         # generated by 01-server-setup.sh, saved to ~/credentials.txt
REDIS_USERNAME=
REDIS_DB=0
REDIS_CONNECTION_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_MAX_RETRIES=3
REDIS_KEEP_ALIVE=30000
REDIS_LAZY_CONNECT=true
REDIS_ENABLE_READY_CHECK=true
REDIS_ENABLE_OFFLINE_QUEUE=true
REDIS_AUTO_RECONNECT=true
REDIS_PERSISTENT_MODE=false
REDIS_RETRY_DELAY_ON_FAILOVER=100
REDIS_MAX_REDIS_LOADING_TIMEOUT=10000
REDIS_RECONNECT_ON_ERROR=true

# Cache TTLs (seconds)
CACHE_USER_ENABLED=true
CACHE_USER_TTL_DAYS=1
CACHE_DEFAULT_TTL=900
CACHE_PARENT_ACCESS_TTL=7200
CACHE_ADVERTISEMENT_ENABLED=true
CACHE_AD_TTL_SECONDS=3600
CACHE_AD_METRICS_SYNC_INTERVAL_MINUTES=10

# ============================================
# DYNAMODB (Attendance)
# ============================================
DYNAMODB_TABLE_NAME=sms_logs
DYNAMODB_ENABLED=false

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Webhook secret — generate: openssl rand -hex 32
TELEGRAM_SECRET_TOKEN=CHANGE_ME

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# File storage paths (relative)
PROFILE_IMAGES_PATH=profile-images
STUDENT_IMAGES_PATH=student-images
INSTITUTE_IMAGES_PATH=institute-images
HOMEWORK_FILES_PATH=homework-files
CORRECTION_FILES_PATH=teacher-corrections
PAYMENT_RECEIPTS_PATH=payment-receipts

# ============================================
# SECURITY — 15-Layer Access Control
# ============================================
IS_ENABLED_ADMIN=true
IS_ENABLED_USER_CACHE=true
IS_ENABLED_PARENT_CACHE=true
IS_ENABLED_STUDENT_CACHE=true
IS_ENABLED_INSTITUTE_CACHE=true
IS_ENABLED_TEACHER_CACHE=true
IS_ENABLED_SUBJECT_CACHE=true
IS_ENABLED_CLASS_CACHE=true
IS_ENABLED_PAYMENT_CACHE=true
IS_ENABLED_AUDIT_CACHE=true
IS_ENABLED_SECURITY_LAYER=true
IS_ENABLED_VALIDATION_LAYER=true
IS_ENABLED_ENCRYPTION_LAYER=true
IS_ENABLED_BACKUP_LAYER=true
IS_ENABLED_MONITORING_LAYER=true

# ============================================
# SSL/TLS (production)
# ============================================
SSL_ENABLED=true
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt
SSL_CA_PATH=./ssl/ca-bundle.crt

# ============================================
# SECURITY — IP Controls
# ============================================
# Enable strict X-Forwarded-For validation (recommended true in production)
ENHANCED_IP_VALIDATION=true

# Comma-separated CIDR ranges allowed to hit admin endpoints (leave empty to disable)
ADMIN_IP_RANGES=
PRIVILEGED_ADMIN_IP_RANGES=

# Explicit block/allow lists (optional)
IP_BLACKLIST=
IP_WHITELIST=

# ISO-3166 country codes to block, e.g. CN,RU,KP (optional)
BLOCKED_COUNTRIES=

# ============================================
# ATTENDANCE
# ============================================
ATTENDANCE_TTL_YEARS=5
MAX_BULK_ATTENDANCE_SIZE=500

# DynamoDB table for legacy BookHire attendance (leave empty if unused)
DYNAMODB_BOOKHIRE_ATTENDANCE_TABLE=

# ============================================
# DATABASE RESET (DANGER — dev only)
# ============================================
DEFAULT_MIGRATION_PASSWORD=CHANGE_ME

# ============================================
# ATTENDANCE SYNC (DynamoDB → MySQL)
# ============================================
# ATTENDANCE_SYNC_MODE=DYNAMO_FIRST
# ATTENDANCE_SYNC_ENABLED=true
# ATTENDANCE_SYNC_CRON=0 */15 * * * *
# ATTENDANCE_SYNC_BATCH_SIZE=500

# Attendance notifications and advertisement delivery
ENABLE_ATTENDANCE_NOTIFICATIONS=true
ENABLE_ADVERTISEMENT_DELIVERY=true
IS_ADS_FROM_DB=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# PRODUCTION READINESS
# ============================================
FORCE_HTTPS=true
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# =============================================================================
# SECURITY CHECKLIST (before first deployment):
#   [ ] Generated unique random values for every CHANGE_ME field
#       Use: openssl rand -hex 64  (for JWT, BCRYPT_PEPPER, UPLOAD_TOKEN_SECRET)
#            openssl rand -hex 32  (for SPECIAL_API_KEY, DRIVE_TOKEN_ENCRYPTION_KEY, TELEGRAM_SECRET_TOKEN)
#   [ ] DB_PASSWORD matches the db_password set in terraform.tfvars
#   [ ] REDIS_PASSWORD matches ~/credentials.txt from 01-server-setup.sh
#   [ ] BCRYPT_PEPPER is backed up securely — losing it breaks ALL password hashes
#   [ ] .env is NOT committed to git (verify with: git status)
#   [ ] BACKUP_BUCKET set to:  terraform output -raw backup_bucket
#   [ ] FIREBASE_PRIVATE_KEY newlines entered as \n within double-quoted value
#   [ ] GCS_PRIVATE_KEY newlines entered as \n within double-quoted value
# =============================================================================

# -----------------------------------------------------------------------------
# 2.15 PayHere Payment Gateway
# -----------------------------------------------------------------------------
PAYHERE_MERCHANT_ID=1236300
# Web domain secret — PayHere entry: suraksha.lk (decoded from Base64)
PAYHERE_MERCHANT_SECRET_WEB=decoded_web_secret_here
# App secret — PayHere entry: lk.suraksha.lms (decoded from Base64)
PAYHERE_MERCHANT_SECRET_APP=decoded_app_secret_here
# sandbox | live  (only the gateway URL changes)
PAYHERE_MODE=sandbox
APP_BASE_URL=https://lms.suraksha.lk
API_BASE_URL=https://lmsapi.suraksha.lk
