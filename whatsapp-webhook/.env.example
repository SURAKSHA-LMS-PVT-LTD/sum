# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
# App Secret from Meta Developer Console → App Settings → Basic → App Secret
# Required for X-Hub-Signature-256 verification of every incoming POST.
# NEVER leave empty in production — anyone who finds the webhook URL can forge messages.
WHATSAPP_APP_SECRET=your_meta_app_secret_here
# The business WhatsApp number users send OTPs TO (digits, e.g. 94771234567).
# Must match WHATSAPP_BUSINESS_NUMBER configured on the main backend.
WHATSAPP_BUSINESS_NUMBER=94771234567

# MySQL — same DB as Suraksha LMS backend
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=suraksha_user
DB_PASSWORD=your_db_password_here
DB_DATABASE=suraksha_lms

# Server
PORT=4000
